        <field name="template_id" ref="payment_schedule_hong_hac_villa"/>
        <field name="sequence">60</field>
        <field name="code">dot_6</field>
        <field name="name">Đợt 6</field>
        <field name="date_type">offset</field>
        <field name="offset_months">7</field>
        <field name="amount_type">percentage</field>
        <field name="percentage">3.0</field>
        <field name="vat_share">3.0</field>
        <field name="bank_share">0</field>
        <field name="bank_vat_share">0</field>
        <field name="is_mergeable" eval="True"/>
        <field name="group_merge">1</field>
    </record>
    <record id="psl_hhv_dot_7" model="payment.schedule.template.line">
        <field name="template_id" ref="payment_schedule_hong_hac_villa"/>
        <field name="sequence">70</field>
        <field name="code">dot_7</field>
        <field name="name">Đợt 7</field>
        <field name="date_type">offset</field>
        <field name="offset_months">10</field>
        <field name="amount_type">percentage</field>
        <field name="percentage">3.0</field>
        <field name="vat_share">3.0</field>
        <field name="bank_share">0</field>
        <field name="bank_vat_share">0</field>
        <field name="is_mergeable" eval="True"/>
        <field name="group_merge">1</field>
    </record>
    <record id="psl_hhv_dot_8" model="payment.schedule.template.line">
        <field name="template_id" ref="payment_schedule_hong_hac_villa"/>
        <field name="sequence">80</field>
        <field name="code">dot_8</field>
        <field name="name">Đợt 8</field>
        <field name="date_type">offset</field>
        <field name="offset_months">13</field>
        <field name="amount_type">percentage</field>
        <field name="percentage">3.0</field>
        <field name="vat_share">3.0</field>
        <field name="bank_share">0</field>
        <field name="bank_vat_share">0</field>
        <field name="is_mergeable" eval="True"/>
        <field name="group_merge">1</field>
    </record>
    <!-- Đợt 9-11: mỗi đợt 5% / 5% VAT — 3 đợt = 15% / 15% VAT -->
    <record id="psl_hhv_dot_9" model="payment.schedule.template.line">
        <field name="template_id" ref="payment_schedule_hong_hac_villa"/>
        <field name="sequence">90</field>
        <field name="code">dot_9</field>
        <field name="name">Đợt 9</field>
        <field name="date_type">offset</field>
