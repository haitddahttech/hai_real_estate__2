    <record id="psl_hhv_thong_bao_so_hong" model="payment.schedule.template.line">
        <field name="template_id" ref="payment_schedule_hong_hac_villa"/>
        <field name="sequence">140</field>
        <field name="code">thong_bao_so_hong</field>
