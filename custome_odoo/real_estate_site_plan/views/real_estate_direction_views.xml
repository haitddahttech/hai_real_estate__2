<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List view -->
    <record id="real_estate_direction_view_list" model="ir.ui.view">
        <field name="name">real.estate.direction.list</field>
        <field name="model">real.estate.direction</field>
        <field name="arch" type="xml">
            <list string="Hướng bất động sản" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- Form view -->
    <record id="real_estate_direction_view_form" model="ir.ui.view">
        <field name="name">real.estate.direction.form</field>
        <field name="model">real.estate.direction</field>
        <field name="arch" type="xml">
            <form string="Hướng bất động sản">
                <sheet>
                    <widget name="web_ribbon" title="Đã lưu trữ" bg_color="bg-danger"
                            invisible="active"/>
                    <group>
                        <group>
                            <field name="name" placeholder="Bắc, Đông Nam..."/>
                            <field name="code" placeholder="north, southeast..."/>
                        </group>
                        <group>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search view -->
    <record id="real_estate_direction_view_search" model="ir.ui.view">
        <field name="name">real.estate.direction.search</field>
        <field name="model">real.estate.direction</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
                <filter string="Đang dùng" name="active" domain="[('active','=',True)]"/>
                <filter string="Đã lưu trữ" name="inactive" domain="[('active','=',False)]"/>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_real_estate_direction" model="ir.actions.act_window">
        <field name="name">Hướng bất động sản</field>
        <field name="res_model">real.estate.direction</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="real_estate_direction_view_search"/>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Tạo hướng bất động sản đầu tiên
            </p>
            <p>
                Cấu hình danh mục các hướng dùng cho sản phẩm bất động sản
                (Bắc, Đông Nam, Tây Bắc...).
            </p>
        </field>
    </record>

    <!-- Menu under "Cấu hình" -->
    <menuitem id="menu_real_estate_direction"
              name="Hướng"
              parent="menu_configuration"
              action="action_real_estate_direction"
              sequence="15"/>

</odoo>
