<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Wizard Form -->
    <record id="view_product_price_import_wizard_form" model="ir.ui.view">
        <field name="name">product.price.import.wizard.form</field>
        <field name="model">product.price.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Import giá sản phẩm BĐS">
                <!-- STEP 1: choose file -->
                <group invisible="state == 'done'">
                    <div class="alert alert-info" role="alert" colspan="2">
                        <p class="mb-1"><strong>📥 Hướng dẫn nhanh</strong></p>
                        <ol class="mb-0">
                            <li>Bấm <b>Tải template kèm dữ liệu</b> để xuất danh sách sản phẩm hiện tại ra Excel.</li>
                            <li>Sửa các cột <b>B, C, F, G, H, I</b> trong Excel — KHÔNG đổi cột A (Mã căn).</li>
                            <li>Upload file đã sửa vào ô bên dưới, bấm <b>Import</b>.</li>
                        </ol>
                    </div>
                </group>

                <group invisible="state == 'done'">
                    <group string="Tải template">
                        <field name="only_real_estate"/>
                        <div colspan="2" class="o_row">
                            <button name="action_download_blank"
                                    type="object"
                                    string="📄 Tải template trống"
                                    class="btn-secondary"/>
                            <button name="action_download_with_data"
                                    type="object"
                                    string="📊 Tải template kèm dữ liệu hiện tại"
                                    class="btn-primary"/>
                        </div>
                    </group>
                    <group string="Upload &amp; Import">
                        <field name="file" filename="filename" widget="binary"/>
                        <field name="filename" invisible="1"/>
                    </group>
                </group>

                <!-- STEP 2: result -->
                <group invisible="state != 'done'">
                    <div class="alert alert-success" role="alert" colspan="2"
                         invisible="error_count != 0 or update_count == 0">
                        <strong>✅ Import thành công!</strong>
                    </div>
                    <div class="alert alert-warning" role="alert" colspan="2"
                         invisible="error_count == 0">
                        <strong>⚠️ Import hoàn tất nhưng có lỗi — xem chi tiết bên dưới.</strong>
                    </div>
                    <div class="alert alert-secondary" role="alert" colspan="2"
                         invisible="update_count != 0 or error_count != 0">
                        <strong>ℹ️ Không có bản ghi nào được cập nhật.</strong>
                    </div>

                    <group>
                        <field name="update_count" readonly="1"/>
                        <field name="skipped_count" readonly="1"/>
                        <field name="error_count" readonly="1"/>
                    </group>
                    <field name="import_log" widget="text" readonly="1" nolabel="1"
                           style="font-family: monospace; white-space: pre-wrap;"/>
                </group>

                <footer>
                    <button name="action_import"
                            type="object"
                            string="🚀 Import"
                            class="btn-primary"
                            invisible="state == 'done'"
                            confirm="Bạn chắc chắn muốn cập nhật giá theo file Excel này?"/>
                    <button string="Đóng" special="cancel" class="btn-secondary"
                            invisible="state == 'done'"/>
                    <button string="Xong" special="cancel" class="btn-primary"
                            invisible="state != 'done'"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Action to open wizard -->
    <record id="action_product_price_import_wizard" model="ir.actions.act_window">
        <field name="name">Import giá sản phẩm</field>
        <field name="res_model">product.price.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- Inherit list view of action_real_estate_products: add header button -->
    <record id="view_real_estate_products_list_inherit" model="ir.ui.view">
        <field name="name">product.template.list.real.estate.inherit</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_tree_view"/>
        <field name="mode">primary</field>
        <field name="priority">20</field>
        <field name="arch" type="xml">
            <xpath expr="//list" position="inside">
                <header>
                    <button name="%(action_product_price_import_wizard)d"
                            type="action"
                            string="📥 Import giá"
                            class="btn-primary"
                            context="{}"/>
                </header>
            </xpath>
        </field>
    </record>

    <!-- Wire the primary list view into Real Estate Products action -->
    <record id="action_real_estate_products" model="ir.actions.act_window">
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('view_real_estate_products_list_inherit')}),
            (0, 0, {'view_mode': 'form'})]"/>
    </record>

    <!-- Configuration menu entry as well -->
    <menuitem id="menu_product_price_import"
              name="Import giá sản phẩm"
              parent="menu_configuration"
              action="action_product_price_import_wizard"
              sequence="40"/>

</odoo>
